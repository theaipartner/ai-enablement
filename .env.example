# Copy to .env.local and fill in real values. .env.local is gitignored.
# Every env var read by anything in shared/ should be documented here.

# --- Supabase ------------------------------------------------------------
# Project URL. Local dev: http://127.0.0.1:54321 (from `supabase status`).
# Cloud: Project Settings → API → Project URL on the Supabase dashboard.
SUPABASE_URL=http://127.0.0.1:54321

# Service role key — bypasses RLS. Server-side only, never ship to the browser.
# Local dev: `supabase status` prints it as "Secret". Cloud: Project Settings →
# API → Project API keys → service_role (secret) on the dashboard.
SUPABASE_SERVICE_ROLE_KEY=replace-me

# --- Gregory dashboard (Next.js) -----------------------------------------
# The dashboard runs in the browser as well as on the server, so its
# Supabase config must be exposed via Next.js' NEXT_PUBLIC_* convention.
# These two are read by lib/supabase/{client,server}.ts and middleware.ts.
#
# NEXT_PUBLIC_SUPABASE_URL: same value as SUPABASE_URL above. Duplicated
# under the NEXT_PUBLIC_ prefix so the Next.js compiler can inline it
# into client bundles. Setting only SUPABASE_URL would not work for the
# dashboard.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# NEXT_PUBLIC_SUPABASE_ANON_KEY: the anon / public key, NOT the service
# role key. The dashboard authenticates real users via Supabase Auth and
# relies on RLS (V2) plus the app-level auth gate (V1) — service role
# would bypass both. Cloud: Project Settings → API → Project API keys →
# anon / public on the Supabase dashboard. Local dev: `supabase status`
# prints it as "anon key".
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me

# --- Anthropic (Claude) --------------------------------------------------
# Claude API key. Used by shared/claude_client.py for every agent call.
# Create at https://console.anthropic.com/settings/keys.
ANTHROPIC_API_KEY=replace-me

# --- OpenAI (embeddings) -------------------------------------------------
# OpenAI API key. Used by shared/kb_query.py for text-embedding-3-small.
# Embedding model only — generation still goes through Anthropic.
# Create at https://platform.openai.com/api-keys.
OPENAI_API_KEY=replace-me

# --- Slack ----------------------------------------------------------------
# Bot User OAuth Token for Slack ingestion and Ella's bot responses.
# Starts with xoxb-. From api.slack.com/apps → your app → OAuth & Permissions.
SLACK_BOT_TOKEN=replace-me

# Signing secret used by api/slack_events.py to verify inbound webhooks
# from Slack's Events API. From api.slack.com/apps → your app → Basic
# Information → App Credentials → Signing Secret. Must be the exact env
# var name `SLACK_SIGNING_SECRET` (underscore, all caps).
SLACK_SIGNING_SECRET=replace-me

# User OAuth Token (xoxp-) for posting Ella's replies as the @ella user
# rather than as the bot. When set, api/slack_events.py:_post_to_slack
# tries this path first; renders without the APP tag in Slack. Falls
# through to SLACK_BOT_TOKEN on any failure (missing scope, not in
# channel, network blip). Generated via the Slack OAuth flow with
# user_scope=chat:write while logged in as the dedicated Ella user
# account. Save to Bitwarden as SLACK_USER_TOKEN_PROD before pasting
# into Vercel env. See docs/architecture/ella_user_token.md and
# docs/runbooks/slack_webhook.md § User-token deploy.
#
# Operational rollback: unset this variable on Vercel and redeploy →
# posts revert to bot-token path with no code change.
SLACK_USER_TOKEN=replace-me

# --- Fathom ---------------------------------------------------------------
# Webhook signing secret returned (once) by Fathom's `POST /webhooks` when
# registering a webhook. Used by api/fathom_events.py to verify Standard
# Webhooks signatures on inbound `new-meeting-content-ready` deliveries.
# Format: `whsec_<base64>`. Not rotatable via API — rotation = delete the
# existing webhook + create a new one. See docs/architecture/fathom_webhook.md
# §b and the F2.5 deploy runbook.
FATHOM_WEBHOOK_SECRET=replace-me

# Fathom team-account API key with read access to /external/v1/meetings.
# Used by api/fathom_backfill.py to page through recent meetings during
# the daily cron sweep. Distinct from FATHOM_WEBHOOK_SECRET above —
# different auth surfaces (the secret signs inbound webhooks; this key
# authorizes our outbound API calls to Fathom). Generate from the Fathom
# Settings → API Access page on the team account, save to Bitwarden as
# FATHOM_API_KEY_PROD before pasting into Vercel env.
FATHOM_API_KEY=replace-me

# --- Google OAuth (Teams Meeting Tracker) ---------------------------------
# Used by the /teams page's Calendar sync cron (api/teams_calendar_sync_cron.py)
# and the OAuth flow at /api/auth/google/{connect,callback}. V1 stores ONE
# token row keyed to Drake's team_member_id; the four CSMs share their
# calendars with Drake at the Workspace level so Drake's token reads
# every CSM's calendar via per-calendarId API calls.
#
# Create at https://console.cloud.google.com/apis/credentials — OAuth 2.0
# Client ID for "Web application". Authorized redirect URI must be exactly
# `{NEXT_PUBLIC_APP_URL}/api/auth/google/callback` (no trailing slash).
# Scopes required: https://www.googleapis.com/auth/calendar.readonly.
GOOGLE_OAUTH_CLIENT_ID=replace-me
GOOGLE_OAUTH_CLIENT_SECRET=replace-me

# Public base URL of the deployed dashboard. Used to construct the OAuth
# redirect URI (must match what's registered in Google Cloud Console).
# Production: https://ai-enablement-sigma.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Slack user_id of the head CSM (Scott today) who receives a DM on every
# Ella escalation — added alongside the channel's primary CSM so head-CSM
# coverage is automatic across both reactive and passive paths. Unset
# safely degrades: only the primary CSM is DMed, with a logged warning;
# escalations still write to the `escalations` table either way. Set to
# the dedicated head-CSM Slack user_id; when Scott IS the channel's
# primary CSM, the recipient list dedupes to one DM.
ESCALATION_RECIPIENT_SLACK_USER_ID=replace-me

# Optional CC recipient for the weekly Friday FAQ digest cron
# (api/faq_digest_cron.py). When set to a syntactically valid Slack
# user_id (^U[A-Z0-9]+$), the cron DMs both Scott (primary, resolved
# dynamically by name) AND the CC recipient — useful during the
# validation period so Drake can see the same DM Scott sees. Unset =
# current Scott-only behavior. Malformed values log a warning and
# degrade to Scott-only (the cron never crashes on a bad CC value).
# CC equal to Scott's slack_user_id dedupes to one DM.
FAQ_DIGEST_CC_SLACK_USER_ID=

# Optional CC recipient for the daily Ella-flags digest cron
# (api/ella_daily_digest_cron.py). When set to a syntactically valid
# Slack user_id (^U[A-Z0-9]+$), the cron DMs both the head CSM (Scott,
# resolved dynamically from team_members.access_tier='head_csm') AND
# the CC recipient (Drake during the validation period). Unset =
# head-CSM-only. Malformed values log a warning and degrade to
# head-CSM-only (the cron never crashes on a bad CC value). CC equal
# to a primary recipient dedupes to one DM.
ELLA_DAILY_DIGEST_CC_SLACK_USER_ID=

# --- Ella unanswered-message flagger ------------------------------------
# Real-time safety net (api/ella_unanswered_flagger_cron.py): every
# flagged pending_digest_items row that ages past 2h with no team_member
# message in the source channel is posted to #unanswered-channels with
# @-mentions of Scott + the client's primary advisor. Runs every 15 min,
# 24/7. Layered on top of the daily digest — independent state.
#
# Kill switch. Defaults to 'true' when unset; any value other than
# 'true' (case-insensitive) disables the cron (it writes a disabled
# audit row and returns 200 without doing work).
ELLA_UNANSWERED_FLAGGER_ENABLED=true
# Slack channel ID for #unanswered-channels. REQUIRED in production —
# the cron returns 500 + a config-gap audit row when unset. Gate (d):
# Drake sets this in Vercel Production env vars.
ELLA_UNANSWERED_CHANNEL_SLACK_ID=

# --- Airtable onboarding webhook (Path 3 inbound) -----------------------
# Shared secret with Make.com for the onboarding form receiver
# (api/airtable_onboarding_webhook.py). Make.com fires this once per new
# client when Zain's onboarding flow (Slack channel created → client
# invited → form submitted) completes. The receiver validates the header
# via hmac.compare_digest and the RPC create_or_update_client_from_onboarding
# does the match-or-create work in one transaction.
#
# Generate with `openssl rand -hex 32` or `python -c "import secrets;
# print(secrets.token_urlsafe(32))"`. Save to Bitwarden as
# AIRTABLE_ONBOARDING_WEBHOOK_SECRET_PROD before pasting into Vercel
# Production env, then mirror into Make.com's HTTP module headers as
# X-Webhook-Secret. See docs/runbooks/airtable_onboarding_webhook.md
# § Rotate the shared secret.
AIRTABLE_ONBOARDING_WEBHOOK_SECRET=replace-me

# --- Cron auth (shared by ALL cron endpoints) ---------------------------
# Single project-level Bearer token Vercel Cron uses for every cron in
# this project. Vercel only supports one CRON_SECRET per project (the
# env var name is fixed by Vercel's cron infrastructure), so all cron
# handlers in api/ validate against the same env var:
#   - api/fathom_backfill.py
#   - api/gregory_brain_cron.py
#   - api/accountability_notification_cron.py
#
# Generate with `openssl rand -hex 32` or `python -c "import secrets;
# print(secrets.token_urlsafe(32))"`. Save to Bitwarden as
# CRON_SECRET_PROD, set in Vercel Production env, then redeploy. To
# rotate: change the value in Vercel and redeploy — single source of
# truth means no synchronization across multiple env vars.
#
# Manual triggers via curl use this same token:
#   curl -H "Authorization: Bearer $CRON_SECRET" \
#     https://ai-enablement-sigma.vercel.app/api/<cron_path>
#
# Consolidated to this single-var pattern in M6.2. Earlier versions of
# the codebase had per-source-named cron tokens under a "namespacing
# for independent rotation" rationale that was never deliverable —
# Vercel only sends `Authorization: Bearer <CRON_SECRET>`, so per-source
# naming required operators to set both env vars in sync, which silently
# failed for the M6.1 cron deploy. See the M6.2 commit for the full
# refactor.
CRON_SECRET=replace-me

# --- CS visibility surfaces (Batch A — M6.1) -----------------------------
# Slack channel ID where the per-call CS summary auto-post lands.
# Posted by ingestion/fathom/pipeline.py via agents/gregory/cs_call_summary_post.py
# whenever a Fathom webhook delivers a `call_category='client'` call.
# Channel must have the bot installed; see docs/runbooks/cs_call_summary.md.
SLACK_CS_CALL_SUMMARIES_CHANNEL_ID=replace-me

# Slack channel ID where the daily 7am EST accountability notification
# posts one message per CSM listing clients who didn't submit accountability
# yesterday. Posted by api/accountability_notification_cron.py. Same bot
# installation requirement as above. See docs/runbooks/accountability_notification_cron.md.
SLACK_CS_ACCOUNTABILITY_CHANNEL_ID=replace-me

# Airtable Personal Access Token authorizing reads on the accountability
# table. The accountability cron filters records by date and reads each
# row's Email field to determine who submitted yesterday. PAT scope:
# data.records:read on the AIRTABLE_ACCOUNTABILITY_BASE_ID base.
# Save to Bitwarden as AIRTABLE_ACCOUNTABILITY_PAT_PROD before pasting
# into Vercel. Rotation: regenerate at airtable.com/create/tokens.
AIRTABLE_ACCOUNTABILITY_PAT=replace-me

# Airtable base + table identifiers for the accountability table. Both
# are stable and grouped here so changing either is a single env edit
# instead of a code push. Today's values (2026-05-05):
#   base = appR566PxMuP71mD6
#   table = tblmHH0TVpMa0xYTU
AIRTABLE_ACCOUNTABILITY_BASE_ID=replace-me
AIRTABLE_ACCOUNTABILITY_TABLE_ID=replace-me

# --- Close CRM (discovery — no production code yet) ----------------------
# Close API key used by scripts/explore_close_api.py for the read-only
# Smartview discovery probe (see docs/specs/close-smartview-discovery.md
# + docs/reports/close-smartview-discovery.md). Local-only for now —
# this key is NOT set in Vercel because no production code path
# consumes it yet. When the eventual `ingestion/close/` module lands,
# this entry stays; the production Vercel value gets set then.
#
# Generate in Close UI: Settings → Developer → API Keys.
#
# Auth pattern: HTTP Basic where the key is the *username* and the
# password is empty (the request sends `<api_key>:` base64-encoded).
# A 401 is almost always the trailing-colon detail — confirm that
# before troubleshooting anything else.
CLOSE_API_KEY=replace-me

# Close webhook signing secret. Issued ONCE by Close in the response to
# POST /api/v1/webhook/ when the subscription is registered — see
# scripts/register_close_webhook.py and docs/runbooks/close_ingestion.md
# § Live activation. Hex string (format: 64 hex chars).
#
# Used by api/close_events.py to verify the close-sig-hash header:
#   hmac.new(bytes.fromhex(secret), (close-sig-timestamp + body).encode(),
#            hashlib.sha256).hexdigest()
#
# Gate (d) for setting in Vercel — Drake adds after registering the
# subscription. Local file is optional (only needed for local replay
# testing of received payloads).
CLOSE_WEBHOOK_SECRET=replace-me

# --- Wistia (video analytics ingestion) ----------------------------------
# Wistia Data + Stats API token. Used by ingestion/wistia/client.py
# (HTTP Bearer auth) for the video-analytics mirror that feeds the
# Engine sheet's FUNNELS section (VSL Engagement Rate, VSL Avg View
# Duration, TYP Engagement Rate, TYP Avg View Duration).
#
# Generate at: Wistia → Account Settings → API Access. Note: the
# token page is Account-Owner-only (Nabeel). If 401s start happening
# in the cron audit ledger, the token may have been rotated and needs
# re-minting with the "Read detailed stats" permission scope.
#
# Required in BOTH locations:
#   - .env.local — for `scripts/backfill_wistia.py` and local probe runs
#   - Vercel project env — for `api/wistia_sync_cron.py` (the live cron)
# Setting only one place will leave the other side broken. Gate (d)
# for adding to Vercel.
WISTIA_API_TOKEN=replace-me


# --- Calendly (scheduled events + invitees ingestion) --------------------
# Calendly Personal Access Token (JWT, ~896 chars). Used by
# ingestion/calendly/client.py (HTTP Bearer auth) for the events +
# invitees mirror that feeds the Engine sheet's six Calendly-sourced
# rows (FUNNELS section: New Scheduled / Rescheduled / Follow Up
# Meetings + Closer Bookings + Next Day + Two Days Out).
#
# Generate at: Calendly → Integrations → API & Webhooks → Personal
# Access Tokens. Account-Owner or Admin tier required.
#
# Required in BOTH locations:
#   - .env.local — for scripts/backfill_calendly.py + register helper
#   - Vercel project env — for api/calendly_events.py webhook receiver
#     (the receiver fetches the parent event per invitee tick).
# Setting only one place leaves the other side broken. Gate (d) for
# adding to Vercel.
#
# Spec drift note: docs/specs/calendly-ingestion.md referenced
# CALENDLY_API_TOKEN; this canonical name CALENDLY_API_KEY matches the
# CLOSE_API_KEY / OPENAI_API_KEY / ANTHROPIC_API_KEY precedent.
# The ingestion client accepts either for backwards-compat.
CALENDLY_API_KEY=replace-me

# Calendly webhook signing secret. Returned ONCE by POST
# /api/v1/webhook_subscriptions when the subscription is registered —
# see scripts/register_calendly_webhook.py and
# docs/runbooks/calendly_ingestion.md § Live activation runbook.
# Plain string (UTF-8 bytes used as HMAC key).
#
# Used by api/calendly_events.py to verify the Calendly-Webhook-Signature
# header. Header format: `t=<unix_ts>,v1=<hex>`. HMAC algorithm:
#   hmac.new(secret.encode('utf-8'),
#            f"{ts}.{body}".encode('utf-8'),
#            hashlib.sha256).hexdigest()
# Constant-time compared against the v1 portion of the header.
#
# Gate (d) for setting in Vercel — Drake adds AFTER running
# register_calendly_webhook.py against the deployed receiver URL.
# Local file is optional (only needed for local replay testing).
CALENDLY_WEBHOOK_SECRET=replace-me

# --- Typeform (lead opt-in mirror) ---------------------------------------
# Typeform Personal Access Token. Used by ingestion/typeform/client.py
# (HTTP Bearer auth) for the lead-stream mirror — top-of-funnel opt-ins
# from the Setter / Closer / Organic / etc. funnel forms. NOT client
# data; mirror is self-contained, no clients-table resolution.
#
# Generate at: Typeform → Settings → Personal tokens. Scope needs read
# access to forms + responses + webhooks.
#
# Spec used TYPEFORM_API_TOKEN; the actual var name kept here is
# TYPEFORM_API_KEY because that's what was already in .env.local at
# discovery time (see docs/reports/typeform-discovery.md §4(a)). The
# client.py from_env() accepts either name — both forms work.
#
# Required in BOTH locations:
#   - .env.local — for `scripts/backfill_typeform.py`, registration
#     helper, and local diagnostics
#   - Vercel project env — for `api/typeform_sync_cron.py` (cron) +
#     `api/typeform_events.py` (the receiver's lazy form-definition sync)
# Gate (d) for adding to Vercel.
TYPEFORM_API_KEY=replace-me

# Typeform webhook signing secret. Caller-SUPPLIED (we choose the
# value; Typeform does NOT mint it for us — unlike Close, which issues
# the secret in the registration response). Same secret value goes into
# (i) Vercel env var, and (ii) the PUT body the registration script
# sends. They MUST match exactly or every delivery fails signature
# verification.
#
# Generate (long random hex):
#     openssl rand -hex 32
#
# Used by api/typeform_events.py to verify the Typeform-Signature header:
#   base64( hmac.new(secret.encode(), raw_body, hashlib.sha256).digest() )
# Header form: `Typeform-Signature: sha256=<base64>`.
#
# Required in BOTH locations:
#   - .env.local (or `export`ed for the registration-script run)
#   - Vercel project env
# Gate (d) for adding to Vercel. Activation flow lives in
# docs/runbooks/typeform_ingestion.md § 8-step activation runbook.
TYPEFORM_WEBHOOK_SECRET=replace-me


# --- Microsoft Clarity (page metrics — landing + thank-you) --------------
# Clarity Personal Access Token. Used by ingestion/clarity/client.py
# (Bearer auth) for the per-URL per-day page-metrics mirror — source for
# Engine-sheet FUNNELS rows 25 (Landing Page Visits), 26 (Avg Time on
# Landing Page), and 37 (Avg Time on Thank-You Page).
#
# Generate at: Clarity → Settings → Data Export → Generate new API token.
# Admin-only — if Drake isn't admin, Nabeel runs it. 4-32 chars,
# alphanumerics + - _ . only. No spaces or special chars.
#
# Required in BOTH locations:
#   - .env.local — for scripts/sync_clarity.py + tests
#   - Vercel project env — for api/clarity_sync_cron.py daily cron
# Gate (d) for adding to Vercel. Setting only one place leaves the cron
# failing with `clarity_token_unavailable` in the audit row.
#
# The Clarity API has a 10-req/project/day hard cap. The cron uses 1/day.
# Coordinate with manual --apply / --smoke runs during incident debugging
# (each manual call also burns the shared budget).
CLARITY_API_KEY=replace-me

# --- Airtable sales-funnel mirror (Setter Triage + Full Closer US/AUS) ---
# Airtable Personal Access Token. Used by ingestion/airtable/client.py
# (HTTP Bearer auth) for the sales-funnel mirror of base appCWa6TV6p7EBarC
# (Setter Triage Calls + Full Closer Report US + AUS). Feeds Engine-sheet
# Closing section rows 96-116 + setter-side Appointment Setting rows.
#
# Generate at: airtable.com/create/tokens. Required scopes:
#   - schema.bases:read   (probe-only; not used at runtime)
#   - data.records:read   (REQUIRED — records list + per-record fetch +
#                          webhook payload pull)
#   - webhook:manage      (REQUIRED to register/list/refresh/delete the
#                          webhook. NOT yet granted at ingestion ship —
#                          Drake adds before running register_airtable_
#                          webhook.py)
# PAT's allow-list MUST include base appCWa6TV6p7EBarC.
#
# Why a SEPARATE PAT from AIRTABLE_ACCOUNTABILITY_PAT: the accountability
# PAT is in production use (api/accountability_roster.py + cron). Keeping
# a dedicated sales-funnel PAT enables independent rotation + least-
# privilege (this PAT doesn't need accountability base access, and vice
# versa).
#
# Required in BOTH locations:
#   - .env.local — for scripts/backfill_airtable.py + register helper + tests
#   - Vercel project env — for api/airtable_sync_cron.py + api/airtable_events.py
# Gate (d) for adding to Vercel.
AIRTABLE_SALES_PAT=replace-me

# Airtable webhook MAC secret. Returned ONCE by
# scripts/register_airtable_webhook.py --apply at subscription creation
# (Airtable's `macSecretBase64`). Used by api/airtable_events.py to
# verify the X-Airtable-Content-MAC header on every notification ping.
#
# Format: base64-encoded bytes. The receiver base64-decodes this and
# HMAC-SHA256s the raw request body with the decoded key, then compares
# constant-time against the signature in the header (with `hmac-sha256=`
# prefix or bare base64 — both accepted).
#
# Gate (d). Required in Vercel for the receiver to function. NOT needed
# locally unless replay-testing the receiver.
AIRTABLE_WEBHOOK_MAC_SECRET=replace-me

# Airtable webhook id (achXXX). Returned by register_airtable_webhook.py
# at creation. Used by:
#   - api/airtable_events.py — to identify which webhook to pull payloads
#     from (single base-level webhook covers all 3 target tables)
#   - api/airtable_sync_cron.py — to refresh the subscription every tick
#     (Airtable webhooks expire after 7 days of inactivity unless
#     refreshed)
#
# Gate (d). Required in Vercel post-registration. NOT needed locally.
AIRTABLE_WEBHOOK_ID=replace-me

# --- Speed-to-lead API (Zain) --------------------------------------------
# Bearer key for the read-only GET /api/speed-to-lead endpoint, which
# returns the day's average speed-to-lead (overall + under-3h) as JSON.
# This key unlocks ONLY that endpoint — it is NOT a Supabase credential.
# Generate with `openssl rand -hex 32`; set in Vercel (Production) + here
# locally, then hand the value to Zain. Rotate by changing this var.
# Gate (d). Runbook: docs/runbooks/speed_to_lead_api.md.
SPEED_TO_LEAD_API_KEY=replace-me
