# Environment / secrets
.env
.env.local
.env.*.local
.env.local.cloud-backup
*.pem
*.key

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/
*.egg-info/
dist/
build/

# Node / Next.js
node_modules/
.next/
.vercel/
/out/
/coverage/
*.tsbuildinfo
# Auto-generated by `next build`/`next dev`; safe to never commit.
next-env.d.ts

# IDE / OS
# .vscode/settings.json is checked in (shared workspace file-tree
# exclusions, etc.); other .vscode/* files (launch.json, tasks.json,
# personal config) stay ignored.
.vscode/*
!.vscode/settings.json
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# Windows Zone.Identifier files (when copying from Windows)
*:Zone.Identifier

# Logs
*.log

# Local data
/data/
/tmp/
.vercel

# Supabase Studio scratch — ad-hoc SQL snippets saved from the dashboard
# land here. Not part of the checked-in schema; migrations/ is the
# canonical source.
supabase/snippets/

# Director / Builder MCP scaffold — persisted Builder session_id, regenerated
# per delegate call. .claude/settings.local.json is checked in; this file is not.
.claude/builder_session.txt
.preview-cookie

# Transient scheduler lock — regenerated at runtime, never source.
.claude/scheduled_tasks.lock

# Ad-hoc screenshot dumps from exploratory/verification runs — snapshots,
# not source. Regenerate by re-running the capturing script.
screenshots/

# Visual-verification screenshots from scripts/verify-ella-preview.mjs.
# Snapshots of the live preview at run time — not source. Regenerate by
# re-running the script.
scripts/preview-screenshots/

# Throwaway discovery output — e.g. scripts/explore_close_api.py dumps
# raw JSON under .probe-out/close/. Findings get folded into reports;
# the raw dumps stay local.
.probe-out/

# Engine CSV — Drake's local working copy of the daily-tracker sheet
# used during Close-ingestion planning. Not source of truth; the
# canonical sheet lives in Google Sheets. Local file is the reference
# Builder reads at design time per docs/specs/close-ingestion-v1.md.
Data Sheet - Overall Engine.csv

# Lead/booking PII — Typeform CSV exports and one-shot analysis output.
# Regenerable from source + DB; contains emails/phones. Never commit.
Closer Funnel Leads*.csv
lead data/
scripts/out/
